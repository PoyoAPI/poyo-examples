# Copy this file to .env and replace placeholder values.
# Never commit real API keys, production callback URLs, or customer data.

POYO_API_KEY=YOUR_POYO_API_KEY_HERE
POYO_BASE_URL=https://api.poyo.ai

# Optional. Set only after deploying a real public webhook receiver.
# POYO_CALLBACK_URL=https://example.com/api/poyo/webhook

# Optional. Local webhook demos only. Do not enable in production.
POYO_ALLOW_UNLISTED_TASK_IDS=false

# Optional. Comma-separated task IDs accepted by local webhook demos.
# In production, use a database lookup instead of an environment variable.
# POYO_KNOWN_TASK_IDS=task-unified-example

PORT=3000
